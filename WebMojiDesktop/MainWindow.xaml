<Window x:Class="WebMojiDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WebMojiDesktop.UserControl"
        Title="WebMoji" Height="600" Width="1000"
        Closing="OnClosing"
        Background="Black">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:CameraView Grid.Column="0" x:Name="CameraView"/>

        <Image x:Name="GestureImage" Grid.Column="1" Stretch="Uniform"/>
    </Grid>

</Window>