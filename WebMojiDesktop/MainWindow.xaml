<Window x:Class="WebMojiDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:WebMojiDesktop.UserControl"
        Title="WebMoji" Height="449" Width="1153"
        Closing="OnClosing" Background="Black">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <uc:CameraView Grid.Column="0" x:Name="CameraView"/>
        <uc:ImageView  Grid.Column="1" x:Name="ImageView"/>
    </Grid>
</Window>